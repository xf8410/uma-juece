<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#1A1A1A">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp"
        android:text="uma-juece 小黑板"
        android:textColor="#00FF88"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- 剧本选择 -->
    <LinearLayout
        android:id="@+id/scenario_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tv_title"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="剧本："
            android:textColor="#AAAAAA"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/spinner_scenario"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#2A2A2A"
            android:popupBackground="#333333" />

    </LinearLayout>

    <Button
        android:id="@+id/btn_start_float"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="启动悬浮窗"
        android:layout_below="@+id/scenario_row"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp" />

    <Button
        android:id="@+id/btn_test_fake"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="小黑板测试"
        android:layout_below="@+id/btn_start_float"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btn_test_http"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="测试HTTP通信"
        android:layout_below="@+id/btn_test_fake"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btn_stop_float"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="停止悬浮窗"
        android:layout_below="@+id/btn_test_http"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp" />

    <LinearLayout
        android:id="@+id/data_collection_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/btn_stop_float"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_data_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#88CC88"
            android:textSize="12sp"
            android:text="データ収集: 待機中" />

        <Button
            android:id="@+id/btn_upload_data"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="手動UP"
            android:textSize="11sp"
            android:padding="4dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/btn_stop_float"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:textColor="#888888"
        android:textSize="14sp"
        android:text="HTTP服务: 未启动" />

</RelativeLayout>
