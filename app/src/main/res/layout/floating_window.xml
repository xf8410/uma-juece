<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/panel_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#E6000000"
    android:padding="8dp"
    android:minWidth="280dp">

    <!-- 顶部：日期/总属性/体力/干劲/剧本标签 + 关闭按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_turn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#AAAAAA"
            android:textSize="10sp"
            android:text="---" />

        <TextView
            android:id="@+id/tv_scenario_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF9900"
            android:textSize="9sp"
            android:textStyle="bold"
            android:layout_marginEnd="4dp"
            android:text=""
            android:visibility="gone" />

        <TextView
            android:id="@+id/btn_close"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:text="×"
            android:textColor="#666666"
            android:textSize="14sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tv_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:text="" />

        <TextView
            android:id="@+id/tv_stamina"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#66CCFF"
            android:textSize="10sp"
            android:layout_marginStart="6dp"
            android:text="" />

        <TextView
            android:id="@+id/tv_motivation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFCC00"
            android:textSize="10sp"
            android:layout_marginStart="4dp"
            android:text="" />

        <TextView
            android:id="@+id/tv_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF4444"
            android:textSize="9sp"
            android:layout_marginStart="4dp"
            android:text=""
            android:visibility="gone" />
    </LinearLayout>

    <!-- 推荐 -->
    <TextView
        android:id="@+id/tv_recommend"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#00FF88"
        android:textSize="11sp"
        android:textStyle="bold"
        android:paddingTop="3dp"
        android:paddingBottom="1dp"
        android:text="等待数据..." />

    <!-- 比赛/目标状态栏 -->
    <TextView
        android:id="@+id/tv_race_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#888888"
        android:textSize="8sp"
        android:paddingBottom="1dp"
        android:text=""
        android:visibility="gone" />

    <!-- 拉面杯 Gauge 状态栏 -->
    <TextView
        android:id="@+id/tv_ramen_gauge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFAA44"
        android:textSize="8sp"
        android:paddingBottom="1dp"
        android:text=""
        android:visibility="gone" />

    <!-- AI评估详情 -->
    <TextView
        android:id="@+id/tv_ai_detail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#88AA88"
        android:textSize="8sp"
        android:paddingBottom="2dp"
        android:text=""
        android:visibility="gone" />

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp" />

    <!-- 五维属性表 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- 速度 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="2dp">
            <TextView android:id="@+id/tv_spd_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#4488FF" android:textSize="9sp" android:textStyle="bold" android:text="速"/>
            <TextView android:id="@+id/tv_spd_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#4488FF" android:textSize="9sp" android:text="---"/>
            <TextView android:id="@+id/tv_spd_gain" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#6688CC" android:textSize="8sp" android:text=""/>
            <TextView android:id="@+id/tv_spd_lv" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#88AADD" android:textSize="7sp" android:text="" android:visibility="gone"/>
        </LinearLayout>

        <!-- 耐力 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="2dp">
            <TextView android:id="@+id/tv_sta_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FF4444" android:textSize="9sp" android:textStyle="bold" android:text="耐"/>
            <TextView android:id="@+id/tv_sta_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FF4444" android:textSize="9sp" android:text="---"/>
            <TextView android:id="@+id/tv_sta_gain" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#CC6666" android:textSize="8sp" android:text=""/>
            <TextView android:id="@+id/tv_sta_lv" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#DD8888" android:textSize="7sp" android:text="" android:visibility="gone"/>
        </LinearLayout>

        <!-- 力量 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="2dp">
            <TextView android:id="@+id/tv_pwr_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FF8800" android:textSize="9sp" android:textStyle="bold" android:text="力"/>
            <TextView android:id="@+id/tv_pwr_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FF8800" android:textSize="9sp" android:text="---"/>
            <TextView android:id="@+id/tv_pwr_gain" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#CC8844" android:textSize="8sp" android:text=""/>
            <TextView android:id="@+id/tv_pwr_lv" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#DDAA66" android:textSize="7sp" android:text="" android:visibility="gone"/>
        </LinearLayout>

        <!-- 根性 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="2dp">
            <TextView android:id="@+id/tv_gut_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FF66AA" android:textSize="9sp" android:textStyle="bold" android:text="根"/>
            <TextView android:id="@+id/tv_gut_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FF66AA" android:textSize="9sp" android:text="---"/>
            <TextView android:id="@+id/tv_gut_gain" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#CC6688" android:textSize="8sp" android:text=""/>
            <TextView android:id="@+id/tv_gut_lv" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#DD88AA" android:textSize="7sp" android:text="" android:visibility="gone"/>
        </LinearLayout>

        <!-- 智力 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="2dp">
            <TextView android:id="@+id/tv_wit_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FFDD00" android:textSize="9sp" android:textStyle="bold" android:text="智"/>
            <TextView android:id="@+id/tv_wit_val" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#FFDD00" android:textSize="9sp" android:text="---"/>
            <TextView android:id="@+id/tv_wit_gain" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#CCBB44" android:textSize="8sp" android:text=""/>
            <TextView android:id="@+id/tv_wit_lv" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#DDCC66" android:textSize="7sp" android:text="" android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp" />

    <!-- Buff区域 -->
    <LinearLayout
        android:id="@+id/buff_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_buff_ao"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#66AAFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:text="" />

        <TextView
            android:id="@+id/tv_buff_midori"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#66FF88"
            android:textSize="9sp"
            android:textStyle="bold"
            android:text="" />

        <TextView
            android:id="@+id/tv_buff_momo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FF88AA"
            android:textSize="9sp"
            android:textStyle="bold"
            android:text="" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_buff_detail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#999999"
        android:textSize="8sp"
        android:visibility="gone"
        android:text="" />

    <View
        android:id="@+id/buff_separator"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:visibility="gone" />

    <!-- 队员区域（育马者杯专用） -->
    <LinearLayout
        android:id="@+id/team_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_team_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#CC88FF"
                android:textSize="9sp"
                android:textStyle="bold"
                android:text="队员" />

            <TextView
                android:id="@+id/tv_team_members"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#CC88FF"
                android:textSize="8sp"
                android:layout_marginStart="4dp"
                android:text="" />

            <TextView
                android:id="@+id/tv_team_rank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFAA44"
                android:textSize="8sp"
                android:textStyle="bold"
                android:text="" />

            <TextView
                android:id="@+id/tv_dream_training"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#88CCFF"
                android:textSize="8sp"
                android:layout_marginStart="4dp"
                android:text="" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp" />
    </LinearLayout>

    <!-- 底部：设施/Hook状态 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_facility"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#888888"
            android:textSize="9sp"
            android:text="" />

        <TextView
            android:id="@+id/tv_hook_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#555555"
            android:textSize="8sp"
            android:text="Hook:---" />

        <TextView
            android:id="@+id/btn_debug_log"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#666666"
            android:textSize="8sp"
            android:text="LOG"
            android:paddingStart="6dp"
            android:paddingEnd="4dp"
            android:clickable="true"
            android:focusable="true" />
        <TextView
            android:id="@+id/btn_dump"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#666666"
            android:textSize="8sp"
            android:text="DUMP"
            android:paddingStart="6dp"
            android:paddingEnd="4dp"
            android:clickable="true"
            android:focusable="true" />
        <TextView
            android:id="@+id/btn_saddle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#BB88FF"
            android:textSize="8sp"
            android:text="鞍"
            android:paddingStart="6dp"
            android:paddingEnd="2dp"
            android:clickable="true"
            android:focusable="true" />
        <TextView
            android:id="@+id/btn_sniff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF8800"
            android:textSize="8sp"
            android:text="PKT"
            android:paddingStart="6dp"
            android:paddingEnd="2dp"
            android:clickable="true"
            android:focusable="true" />
        <TextView
            android:id="@+id/btn_evt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#00FFAA"
            android:textSize="8sp"
            android:text="EVT"
            android:paddingStart="6dp"
            android:paddingEnd="2dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- 胜鞍分析面板（默认隐藏，点「鞍」按钮展开） -->
    <LinearLayout
        android:id="@+id/saddle_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingTop="2dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#442266"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/tv_saddle_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#CCAAFF"
            android:textSize="8sp"
            android:lineSpacingExtra="1dp"
            android:text="加载中..." />
    </LinearLayout>

    <!-- 抓包面板（默认隐藏，点「PKT」按钮展开） -->
    <LinearLayout
        android:id="@+id/sniff_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingTop="2dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444400"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/tv_sniff_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFCC88"
            android:textSize="7sp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="0dp"
            android:text="点PKT开始抓包" />
    </LinearLayout>

    <!-- 事件推荐面板（默认隐藏，点「EVT」按钮展开） -->
    <LinearLayout
        android:id="@+id/evt_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingTop="2dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#004433"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/tv_evt_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00FFAA"
            android:textSize="10sp"
            android:textStyle="bold"
            android:text="监控中..." />
    </LinearLayout>

</LinearLayout>
